{
  "name": "pas-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "commonjs",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.abogado.pastracker",
    "productName": "PAS Tracker",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^32.0.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.2"
  }
}
